{% extends "base.njk" %}

{# Render the TOC once and count top-level entries. tocCount uses the
   plugin's own parser so the count matches the visible TOC exactly. #}
{% set tocHtml = content | toc %}
{% set tocCount = content | tocCount %}
{% set showToc = tocCount >= 2 %}

{% block bodyClass %}{% if not showToc %}no-toc{% endif %}{% endblock %}

{% block content %}
<div class="layout">
  <nav class="sidebar" aria-label="Documentation navigation">
    {% for group in navigation.groups %}
    <div class="nav-group">
      <p class="nav-group-label">{{ group.group }}</p>
      <ul>
        {% for item in group.pages %}
        <li>
          <a href="/{{ item.path }}/"
             {% if page.url == "/" + item.path + "/" %}class="active"{% endif %}>
            {{ item.title }}
          </a>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </nav>

  <main id="main" class="doc-content">
    {% if title %}
    <h1>{{ title }}</h1>
    {% endif %}

    {% if showToc %}
    <details class="toc-disclosure">
      <summary>On this page</summary>
      <nav aria-label="On this page" class="toc-nav">
        {{ tocHtml | safe }}
      </nav>
    </details>
    {% endif %}

    {{ content | safe }}
  </main>

  {% if showToc %}
  <aside class="toc-rail">
    <nav aria-label="On this page" class="toc-nav">
      <p class="toc-label">On this page</p>
      {{ tocHtml | safe }}
    </nav>
  </aside>
  {% endif %}
</div>
{% endblock %}
