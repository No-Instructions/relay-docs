<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {% set pageTitle = title + " — " + site.title if title else site.title %}
    {% set pageDescription = description or site.description %}
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription }}" />

    <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
    <meta property="og:site_name" content="{{ site.title }}" />
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ pageDescription }}" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ site.url }}{{ page.url }}" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="{{ pageTitle }}" />
    <meta name="twitter:description" content="{{ pageDescription }}" />

    <link rel="stylesheet" href="/styles.css" />
    {% if favicon %}<link rel="icon" href="/favicon.svg" type="image/svg+xml" />{% endif %}

    <!-- Plausible Analytics -->
    <script defer data-domain="docs.relay.md" src="https://plausible.io/js/script.js"></script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <header class="site-header">
      <a href="/" class="site-logo">{{ site.title }}</a>
      <nav class="header-nav">
        <a href="https://relay.md">relay.md</a>
        <a href="https://discord.relay.md">Discord</a>
      </nav>
    </header>

    {% block content %}
      {{ content | safe }}
    {% endblock %}

    <footer class="site-footer">
      <a href="https://relay.md">relay.md</a>
      <a href="https://system3.md">System 3</a>
      <a href="https://discord.relay.md">Discord</a>
    </footer>
  </body>
</html>
